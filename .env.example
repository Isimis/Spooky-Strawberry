SECRET_KEY=change-me-in-local-env
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Na produkcji (przykład):
# DEBUG=False
# ALLOWED_HOSTS=twojadomena.pl,www.twojadomena.pl,TWOJ_IP_SERWERA
# CSRF_TRUSTED_ORIGINS=https://twojadomena.pl,https://www.twojadomena.pl

# Skrzynka pocztowa (SMTP + IMAP) — bez tych wartości maile w dev trafiają na konsolę.
# Po ustawieniu EMAIL_HOST + EMAIL_HOST_USER włącza się realna wysyłka przez SMTP.
# EMAIL_HOST=poczta.twojhosting.pl
# EMAIL_PORT=465
# EMAIL_HOST_USER=kontakt@twojadomena.pl
# EMAIL_HOST_PASSWORD=wpisz-haslo-z-panelu-hostingu
# EMAIL_USE_SSL=True            # port 465; dla portu 587 ustaw EMAIL_USE_TLS=True zamiast tego
# DEFAULT_FROM_EMAIL=Spooky Strawberry <kontakt@twojadomena.pl>
# MAILBOX_IMAP_HOST=poczta.twojhosting.pl
# MAILBOX_IMAP_PORT=993
# MAILBOX_IMAP_USE_SSL=True
# MAILBOX_IMAP_USER=kontakt@twojadomena.pl
# MAILBOX_IMAP_PASSWORD=wpisz-haslo-z-panelu-hostingu
# MAILBOX_IMAP_FOLDER=INBOX
# MAILBOX_SYNC_LIMIT=50
# Lokalnie DEBUG=True automatycznie dodaje [SERWER TESTOWY].
# Na produkcji DEBUG=False zostawia temat bez prefiksu, chyba że ustawisz go ręcznie:
# MAIL_SUBJECT_PREFIX=[SERWER TESTOWY]

# Płatności Przelewy24 — DWA komplety kluczy (Konfiguracja > Klucze / API).
# O tym, który jest używany, decyduje przełącznik w panelu: Ustawienia strony > Tryb płatności.
# Produkcja (secure.przelewy24.pl):
# P24_MERCHANT_ID=123456
# P24_POS_ID=123456
# P24_CRC=xxxxxxxxxxxxxxxx
# P24_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Sandbox (sandbox.przelewy24.pl) — do testów:
# P24_SANDBOX_MERCHANT_ID=123456
# P24_SANDBOX_POS_ID=123456
# P24_SANDBOX_CRC=xxxxxxxxxxxxxxxx
# P24_SANDBOX_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Logowanie przez Google i Apple — bez kluczy przyciski na stronie logowania są nieaktywne.
# Google: console.cloud.google.com → APIs & Services → Credentials → Create OAuth client ID
# (typ "Web application"), redirect URI: https://TWOJADOMENA/konto/social/google/callback/
# (lokalnie dodaj też: http://127.0.0.1:8000/konto/social/google/callback/)
# GOOGLE_OAUTH_CLIENT_ID=xxxxx.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxxxxx
# Apple: developer.apple.com (płatne konto) → Identifiers → Services ID z włączonym
# "Sign in with Apple" i return URL https://TWOJADOMENA/konto/social/apple/callback/
# (Apple wymaga HTTPS — lokalnie nie przetestujesz). Klucz .p8 z sekcji Keys.
# APPLE_OAUTH_CLIENT_ID=pl.twojadomena.signin        # identyfikator Services ID
# APPLE_OAUTH_TEAM_ID=XXXXXXXXXX                     # Team ID (Membership)
# APPLE_OAUTH_KEY_ID=XXXXXXXXXX                      # Key ID klucza .p8
# APPLE_OAUTH_PRIVATE_KEY_FILE=/sciezka/do/AuthKey_XXXXXXXXXX.p8
# …albo zamiast pliku cała zawartość klucza (nowe linie jako \n):
# APPLE_OAUTH_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIG...\n-----END PRIVATE KEY-----

# Dostawa InPost — token Geowidget (mapa wyboru paczkomatu) z panelu InPost/ShipX.
# INPOST_GEOWIDGET_TOKEN=eyJhbGciOi...
# Domyślnie sandbox; na produkcji ustaw False i użyj tokenu produkcyjnego.
# INPOST_GEOWIDGET_SANDBOX=True

# Baza danych
# Lokalnie zostaw puste/usuń — projekt użyje SQLite (db.sqlite3).
# Na serwerze ustaw, by przełączyć się na PostgreSQL:
# DATABASE_URL=postgres://uzytkownik:haslo@localhost:5432/spooky
# DB_SSL_REQUIRE=False
# DB_CONN_MAX_AGE=600

# Zaszyfrowany backup bazy wysyłany codziennie na e-mail (tylko produkcja).
# Hasło musi być długie i unikalne. Nie zapisuj go w Git ani nie wysyłaj mailem.
# BACKUP_EMAIL_ENCRYPTION_PASSWORD=uzupelnij_tutaj
# BACKUP_EMAIL_RECIPIENT=kontakt@spookystrawberry.pl
