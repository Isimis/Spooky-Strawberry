SECRET_KEY=change-me-in-local-env
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Na produkcji (przykład):
# DEBUG=False
# ALLOWED_HOSTS=twojadomena.pl,www.twojadomena.pl,TWOJ_IP_SERWERA
# CSRF_TRUSTED_ORIGINS=https://twojadomena.pl,https://www.twojadomena.pl

# Skrzynka pocztowa (SMTP + IMAP) — bez tych wartości maile w dev trafiają na konsolę.
# Po ustawieniu EMAIL_HOST + EMAIL_HOST_USER włącza się realna wysyłka przez SMTP.
# EMAIL_HOST=poczta.twojhosting.pl
# EMAIL_PORT=465
# EMAIL_HOST_USER=kontakt@twojadomena.pl
# EMAIL_HOST_PASSWORD=wpisz-haslo-z-panelu-hostingu
# EMAIL_USE_SSL=True            # port 465; dla portu 587 ustaw EMAIL_USE_TLS=True zamiast tego
# DEFAULT_FROM_EMAIL=Spooky Strawberry <kontakt@twojadomena.pl>
# MAILBOX_IMAP_HOST=poczta.twojhosting.pl
# MAILBOX_IMAP_PORT=993
# MAILBOX_IMAP_USE_SSL=True
# MAILBOX_IMAP_USER=kontakt@twojadomena.pl
# MAILBOX_IMAP_PASSWORD=wpisz-haslo-z-panelu-hostingu
# MAILBOX_IMAP_FOLDER=INBOX
# MAILBOX_SYNC_LIMIT=50
# Lokalnie DEBUG=True automatycznie dodaje [SERWER TESTOWY].
# Na produkcji DEBUG=False zostawia temat bez prefiksu, chyba że ustawisz go ręcznie:
# MAIL_SUBJECT_PREFIX=[SERWER TESTOWY]

# Płatności Przelewy24 — wartości z panelu (Konfiguracja > Klucze / API).
# Domyślnie sandbox; na produkcji ustaw P24_SANDBOX=False i klucze produkcyjne.
# P24_MERCHANT_ID=123456
# P24_POS_ID=123456
# P24_CRC=xxxxxxxxxxxxxxxx
# P24_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# P24_SANDBOX=True

# Baza danych
# Lokalnie zostaw puste/usuń — projekt użyje SQLite (db.sqlite3).
# Na serwerze ustaw, by przełączyć się na PostgreSQL:
# DATABASE_URL=postgres://uzytkownik:haslo@localhost:5432/spooky
# DB_SSL_REQUIRE=False
# DB_CONN_MAX_AGE=600
