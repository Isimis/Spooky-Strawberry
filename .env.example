SECRET_KEY=change-me-in-local-env
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Na produkcji (przykład):
# DEBUG=False
# ALLOWED_HOSTS=spookystrawberry.pl,www.spookystrawberry.pl,91.228.197.89
# CSRF_TRUSTED_ORIGINS=https://spookystrawberry.pl,https://www.spookystrawberry.pl

# Skrzynka pocztowa (SMTP) — bez tych wartości maile w dev trafiają na konsolę.
# Po ustawieniu EMAIL_HOST + EMAIL_HOST_USER włącza się realna wysyłka przez SMTP.
# EMAIL_HOST=sXXX.cyber-folks.pl
# EMAIL_PORT=465
# EMAIL_HOST_USER=kontakt@twojadomena.pl
# EMAIL_HOST_PASSWORD=tajne-haslo
# EMAIL_USE_SSL=True            # port 465; dla portu 587 ustaw EMAIL_USE_TLS=True zamiast tego
# DEFAULT_FROM_EMAIL=Spooky Strawberry <kontakt@twojadomena.pl>

# Baza danych
# Lokalnie zostaw puste/usuń — projekt użyje SQLite (db.sqlite3).
# Na serwerze ustaw, by przełączyć się na PostgreSQL:
# DATABASE_URL=postgres://uzytkownik:haslo@localhost:5432/spooky
# DB_SSL_REQUIRE=False
# DB_CONN_MAX_AGE=600
